<script>
function filterCards(btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const f = btn.dataset.filter;
  document.querySelectorAll('.case-card').forEach(card => {
    card.classList.toggle('hidden', f !== 'all' && card.dataset.type !== f);
  });
}

function toggleExpand(btn) {
  const body = btn.nextElementSibling;
  const icon = btn.querySelector('i');
  const isOpen = body.classList.toggle('open');
  icon.className = isOpen ? 'ti ti-chevron-up' : 'ti ti-chevron-down';
  btn.childNodes[1].textContent = isOpen ? ' Hide' : ' Parkade relevance';
}


const seoSkills = [
  { label: 'Keyword research', pct: 100 },
  { label: 'Pillar pages',     pct: 90 },
  { label: 'On-page SEO',      pct: 100 },
  { label: 'Ahrefs/Semrush',   pct: 95 },
  { label: 'Internal linking', pct: 90 },
];
// ─────────────────────────────────────────────────────────────────────────────

const container = document.getElementById('bars-seo');
seoSkills.forEach(s => {
  container.insertAdjacentHTML('beforeend',
    `<div class="bar-row">
      <span class="bar-label">${s.label}</span>
      <div class="bar-track"><div class="bar-fill" data-pct="${s.pct}"></div></div>
    </div>`
  );
});
setTimeout(() => {
  document.querySelectorAll('.bar-fill').forEach(b => b.style.width = b.dataset.pct + '%');
}, 300);
</script>
