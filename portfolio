<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marketing Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --text-primary: #1a1a1a; --text-secondary: #555; --text-muted: #888; --text-info: #0c447c;
  --text-success: #27500a; --text-warning: #633806;
  --bg: #f7f7f5; --bg-card: #ffffff; --bg-secondary: #f2f2ef;
  --bg-info: #e6f1fb; --bg-success: #eaf3de; --bg-warning: #faeeda;
  --border: #e4e4e0; --border-soft: #eeeeeb;
  --accent-green: #1a6b3c;
  --radius-md: 8px; --radius-lg: 12px;
  .iframe-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-soft);
    margin: 1.5rem 0;
  }

  .iframe-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
}
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-primary); font-size: 15px; line-height: 1.6; padding: 2rem 1rem; }
.port { max-width: 740px; margin: 0 auto; }

.hero { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2rem 2.25rem; margin-bottom: 1.25rem; }
.hero-eye { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-green); margin-bottom: 6px; }
.hero-name { font-size: 26px; font-weight: 600; margin-bottom: 3px; }
.hero-sub { font-size: 14px; color: var(--text-secondary); margin-bottom: 1.25rem; }
.hero-bio { font-size: 14px; line-height: 1.75; margin-bottom: 1.25rem; }
.tag-row { display: flex; flex-wrap: wrap; gap: 7px; }
.tag { font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: var(--radius-md); background: var(--bg-success); color: var(--text-success); }

.parkade-note { background: var(--bg-success); border: 1px solid #c0dd97; border-radius: var(--radius-md); padding: 0.75rem 1rem; font-size: 13px; color: var(--text-success); margin-bottom: 1.5rem; line-height: 1.6; }
.parkade-note strong { font-weight: 600; }

.sec-label { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.9rem; }

.metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 1.75rem; }
.metric-card { background: var(--bg-secondary); border-radius: var(--radius-md); padding: 1rem 1.1rem; cursor: default; transition: transform 0.15s; }
.metric-card:hover { transform: translateY(-2px); }
.metric-num { font-size: 22px; font-weight: 600; }
.metric-ph { font-size: 13px; font-style: italic; color: var(--text-muted); font-weight: 400; }
.metric-label { font-size: 11px; color: var(--text-secondary); margin-top: 3px; line-height: 1.4; }

hr { border: none; border-top: 1px solid var(--border-soft); margin: 1.75rem 0; }

.filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.25rem; }
.filter-btn { font-size: 12px; padding: 5px 13px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); cursor: pointer; transition: all 0.15s; }
.filter-btn:hover { border-color: #aaa; color: var(--text-primary); }
.filter-btn.active { background: var(--text-primary); color: #fff; border-color: var(--text-primary); }

.case-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem 1.75rem; margin-bottom: 1rem; transition: border-color 0.15s, opacity 0.2s; }
.case-card:hover { border-color: #bbb; }
.case-card.hidden { display: none; }
.case-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
.case-client { font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }
.case-title { font-size: 17px; font-weight: 600; }
.case-type { font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; margin-top: 2px; }
.type-content { background: var(--bg-info); color: var(--text-info); }
.type-rebrand { background: var(--bg-success); color: var(--text-success); }
.type-brand { background: var(--bg-warning); color: var(--text-warning); }

.case-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 10px; }
.case-note { font-size: 12px; color: var(--text-secondary); font-style: italic; line-height: 1.6; border-left: 2px solid var(--border); padding-left: 10px; margin-bottom: 10px; }

.expand-btn { font-size: 12px; color: var(--text-secondary); background: none; border: none; cursor: pointer; padding: 0 0 10px; display: flex; align-items: center; gap: 5px; }
.expand-btn:hover { color: var(--text-primary); }
.expand-body { overflow: hidden; transition: max-height 0.3s ease; max-height: 0; }
.expand-body.open { max-height: 200px; }

.results { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 10px; }
.pill { font-size: 12px; padding: 4px 10px; border-radius: 20px; border: 1px solid var(--border); color: var(--text-primary); background: var(--bg-secondary); }
.pill .ph { font-style: italic; color: var(--text-muted); }
.pill .num { color: var(--accent-green); font-weight: 600; }

.case-footer { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
.sk { font-size: 11px; padding: 3px 8px; border-radius: var(--radius-md); background: var(--bg-secondary); color: var(--text-secondary); border: 1px solid var(--border-soft); }
.live-link { font-size: 12px; color: var(--text-info); text-decoration: none; padding: 4px 10px; border: 1px solid var(--border); border-radius: var(--radius-md); margin-left: auto; display: flex; align-items: center; gap: 5px; transition: background 0.15s; }
.live-link:hover { background: var(--bg-info); }

.skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin-bottom: 1.75rem; }
.skill-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; transition: border-color 0.15s; }
.skill-card:hover { border-color: #bbb; }
.skill-card-title { font-size: 13px; font-weight: 600; margin-bottom: 8px; }
.skill-items { font-size: 12px; color: var(--text-secondary); line-height: 1.9; }

.bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; }
.bar-label { font-size: 11px; color: var(--text-secondary); min-width: 90px; }
.bar-track { flex: 1; height: 4px; background: var(--border-soft); border-radius: 2px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 2px; background: var(--accent-green); width: 0; transition: width 1s ease; }

.cta-bar { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem 1.75rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
.cta-text { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.cta-sub { font-size: 13px; color: var(--text-muted); }
.cta-sub a { color: var(--text-info); text-decoration: none; }

@media (max-width: 520px) {
  .hero, .case-card { padding: 1.25rem; }
  .case-header { flex-direction: column; }
  .hero-name { font-size: 20px; }
}
</style>
</head>
